# ============================================================
# backend/app/.env.production.example
# ============================================================
#
# Purpose:
#   Production environment variable template for the SovCorE Auto
#   backend. Copy to .env and fill in all values before deploying.
#   Never commit the populated .env file — it is gitignored.
#
# Rules (enforced by Settings.assert_production_secrets() at startup):
#   - APP_SECRET_KEY must be at least 32 characters and must not be
#     the placeholder value.
#   - APP_DEBUG must be false.
#   - RESEND_API_KEY must be a real key starting with re_.
#   - DATABASE_URL must point to a real Neon instance.
#
# ============================================================

# Application
APP_ENV=production
APP_SECRET_KEY=                    # Generate: openssl rand -hex 32
APP_DEBUG=false

# Database (Neon PostgreSQL — use the pooled connection string)
DATABASE_URL=                      # postgresql+asyncpg://user:password@ep-xxx.neon.tech/sovcore_auto?sslmode=require

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=                     # Your Cloudflare account ID
R2_ACCESS_KEY_ID=                  # R2 API token access key
R2_SECRET_ACCESS_KEY=              # R2 API token secret key
R2_BUCKET_NAME=sovcore-auto
R2_PUBLIC_URL=                     # https://pub-xxx.r2.dev (or custom domain)

# Resend (email)
RESEND_API_KEY=                    # re_xxx — from Resend dashboard
RESEND_FROM_ADDRESS=noreply@your-domain.com

# CORS — the public frontend origin only (no trailing slash)
CORS_ORIGINS=https://your-domain.com

# Microsoft SSO (OpenID Connect) — leave blank to disable SSO
MS_TENANT_ID=common
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://your-domain.com/api/v1/auth/sso/microsoft/callback

# Rate limiting
RATE_LIMIT_ENABLED=true

# Cron secret — guards scheduled-job trigger endpoints
# Generate: openssl rand -hex 32
CRON_SECRET=
