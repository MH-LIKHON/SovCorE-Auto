# ============================================================
# backend/app/.dockerignore
# ============================================================
#
# Purpose:
#   Files excluded from the Docker build context. Keeping the
#   context lean makes builds faster and prevents secrets from
#   accidentally entering the image layer cache.
#
# ============================================================

# Local environment files — secrets must be injected at runtime.
.env
.env.*
!.env.template

# Python cache and compiled bytecode.
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual environments.
venv/
.venv/
env/

# Test artefacts.
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Alembic migration environment (not needed inside the image —
# migrations run via `alembic upgrade head` as a separate step).
# Include the migrations directory so the image can run migrations.
# alembic/ is therefore NOT excluded here.

# Editor and OS artefacts.
.idea/
.vscode/
*.swp
*.DS_Store
Thumbs.db
