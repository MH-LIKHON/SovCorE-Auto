# ============================================================
# frontend/web/.dockerignore
# ============================================================
#
# Purpose:
#   Files excluded from the Docker build context. node_modules
#   and .next are always rebuilt inside the image from a clean
#   install, so excluding them from the context avoids copying
#   gigabytes of host files that the build would ignore anyway.
#
# ============================================================

# Node dependencies — reinstalled from package.json inside the image.
node_modules/

# Previous build output — rebuilt from source inside the image.
.next/

# Local environment files — NEXT_PUBLIC_* vars come via --build-arg, not via
# .env files. Block all .env variants so a stray .env.production on disk
# cannot silently override the build arg and bake wrong values into the bundle.
.env
.env.*
# Keep the committed templates and examples in the build context (harmless —
# they contain only placeholders, not real values).
!.env.local.template
!.env.production.example

# Editor and OS artefacts.
.idea/
.vscode/
*.swp
*.DS_Store
Thumbs.db

# Test artefacts.
coverage/
.nyc_output/
