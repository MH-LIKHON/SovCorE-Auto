# ============================================================
# frontend/web/.env.production.example
# ============================================================
#
# Purpose:
#   Production environment variable template for the SovCorE Auto
#   frontend. These variables are baked into the Next.js bundle at
#   build time. Copy to .env.production and fill in the values
#   before running `docker compose build`.
#
#   NEXT_PUBLIC_* variables are visible in the browser bundle.
#   Do not place secrets here.
#
# ============================================================

# The public URL where the backend API is reachable from the browser.
# Must match the hostname configured in nginx.conf and Cloudflare.
# No trailing slash.
NEXT_PUBLIC_API_URL=https://your-domain.com

# The public site URL (used for absolute links in emails and OG tags).
NEXT_PUBLIC_SITE_URL=https://your-domain.com
