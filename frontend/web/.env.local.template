# ============================================================
# frontend/web/.env.local.template
# ============================================================
#
# Purpose:
#   Environment variable template for the SovCorE Auto frontend.
#   Copy to .env.local and fill in the values before running
#   the development server.
#
# ============================================================

# Base URL of the FastAPI backend. In development this is the
# local Docker service. In production it is the internal URL
# reached through the Cloudflare Tunnel.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public URL of this frontend, used for OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
