# ============================================================
# frontend/web/.env.local.template
# ============================================================
#
# You only need this file if you run Next.js directly without
# Docker (e.g. `npm run dev` inside frontend/web/).
#
# When running via docker-compose.dev.yml these vars are set
# in the compose file directly — no .env.local needed.
#
# To use: copy to .env.local and fill in the values.
#
# ============================================================

# Base URL of the FastAPI backend, as seen by the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public URL of this frontend, used for OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
